{
  "compilerOptions": {
    "target": "ES2022", "lib": ["ES2022", "DOM"], "module": "commonjs", "moduleResolution": "node10",
    "resolveJsonModule": true, "strict": true, "esModuleInterop": true, "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true, "isolatedModules": true, "declaration": true,
    "declarationMap": true, "sourceMap": true, "outDir": "./dist", "rootDir": "./src",
    "types": ["node"], "ignoreDeprecations": "6.0"
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
